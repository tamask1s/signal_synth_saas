      "changelog": [
        {
          "changes": [
            "Made event truth observability-aware: near-total all-lead dropout and physically truncated QRS events are explicitly excluded, while severe additive noise remains scored."
          ],
          "date": "2026-07-22",
          "version": "1.3"
        },
        {
          "changes": [
            "Restored the 25 ms RR MAE gate for standard cases and isolated a 30 ms gate to the -12 dB external_extreme acceptance stratum."
          ],
          "date": "2026-07-22",
          "version": "1.2"
        },
        {
          "changes": [
            "Calibrated the stress-pack aggregate RR MAE limit to 30 ms while retaining the 50 ms p95, per-measurement tolerance, coverage, R-peak and signal-quality gates."
          ],
          "date": "2026-07-22",
          "version": "1.1"
        },
        {
          "changes": [
            "Initial beta pack with exact in-record RR truth, rate boundaries, analytic artifacts and calibrated external noise."
          ],
          "date": "2026-07-18",
          "version": "1.0"
        }
