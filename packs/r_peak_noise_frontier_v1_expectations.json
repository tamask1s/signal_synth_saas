  "truth_policy": {
    "event_scoreability": "All additive calibrated-noise, baseline-wander and powerline intervals remain scoreable. Only physically truncated record-boundary QRS truth is excluded.",
    "rr_definition": "Difference between consecutive present-QRS construction R-peak times inside the record; an interval touching unscoreable R-peak truth is not_evaluable.",
    "first_beat": "Excluded because no preceding in-record R peak exists for RR construction.",
    "paired_design": "The eight noisy scenarios use the same cardiac timebase, deterministic PVC cadence, interval schedule and noise source offsets; only target SNR and analytic artifact severities increase.",
    "snr_definition": "Target SNR is 20 log10(clean AC RMS / added-noise RMS), calibrated independently for every selected lead and interval. More-negative values are harder.",
    "scope": "R-peak event and RR measurement files are required. Signal-quality labels and HRV are explicitly outside the evidence matrix.",
    "aggregation": "Each SNR case has its own acceptance stratum. Pooled results cannot compensate for a failed tier.",
    "threshold_basis": "Thresholds are a monotone, pre-specified engineering policy for this exact composite synthetic protocol. They are not universal clinical, classical-algorithm or deep-learning performance claims."
  },
  "evidence_boundary": "Synthetic comparative R-peak and beat-to-beat RR engineering evidence only; the SNR ladder is not a patient-noise prevalence model, clinical validation, diagnostic performance evidence, or regulatory qualification."
